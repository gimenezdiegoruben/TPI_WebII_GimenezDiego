extends ../layout

block content
  h1 Nueva publicación

  div.card
    form(id="post-form" method="POST" action="/posts" novalidate)
      p
        label(for="title") Título
      p
        input(type="text", name="title", id="title", placeholder="Ingresa un título para la publicación", required)
      small.error-message(id="error-title")

      p
        label(for="description") Descripción
      p
        textarea(name="description", id="description", rows="4", placeholder="Describe brevemente la publicación", required)
      small.error-message(id="error-description")

      p
        label(for="image") Imagen de la publicación
      p
        input(type="text", name="image", id="image", placeholder="Por ahora URL de imagen. Más adelante se reemplazará por subida de archivo.", required)
      small.error-message(id="error-image")

      p
        label(for="tags") Etiquetas
      p
        input(type="text", name="tags", id="tags", placeholder="Ej: software, tecnología, innovación", required)
      small.error-message(id="error-tags")

      p
        button.btn(type="submit") Guardar publicación

    #post-success-message

  script(src="/js/post-validation.js")