extends ../layout

block content
  h1 Publicaciones

  if saved
    .success-box Publicación validada y enviada correctamente. Más adelante se guardará en la base de datos.

  section.cards
    each post in posts
      div.card
        h2= post.title
        p
          strong Autor:
          |  #{post.author}
        p
          strong Fecha:
          |  #{post.date}
        p= post.description
        a.btn(href=`/posts/${post.id}?auth=ok`) Ver detalle
