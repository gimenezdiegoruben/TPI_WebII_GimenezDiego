extends ../layout

block content
  h1= post.title

  div.card
    p
      strong Autor:
      |  #{post.author}

    p
      strong Fecha:
      |  #{post.date}

    img(src=post.image, alt=post.title, style="max-width:100%; border-radius:10px; margin:15px 0;")

    p= post.description

    a.btn(href="/posts") Volver